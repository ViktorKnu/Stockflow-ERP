{
  "info": {
    "_postman_id": "6a01bd1c-c1db-4c8b-a1c0-5f0c4f10e2f1",
    "name": "StockFlow ERP API",
    "description": "Kjør mappene i rekkefølge for en komplett ERP-flyt. Login lagrer JWT automatisk, og opprettingskallene lagrer ID-er som brukes av senere requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "adminEmail", "value": "admin@stockflow.local", "type": "string" },
    { "key": "adminPassword", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "runId", "value": "", "type": "string" },
    { "key": "supplierId", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "purchaseOrderId", "value": "", "type": "string" },
    { "key": "salesOrderId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "00 - System and authentication",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Application is healthy', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as administrator",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Administrator login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user.role).to.eql('ADMIN');",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('runId', Date.now().toString());",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Suppliers",
      "item": [
        {
          "name": "Create supplier",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Supplier {{runId}}\",\n  \"email\": \"supplier.{{runId}}@postman.test\",\n  \"phone\": \"+47 12345678\",\n  \"address\": \"Testveien 1, Oslo\"\n}"
            },
            "url": "{{baseUrl}}/api/suppliers"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Supplier was created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.collectionVariables.set('supplierId', pm.response.json().id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get supplier",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/suppliers/{{supplierId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Supplier can be read', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(String(pm.response.json().id)).to.eql(pm.collectionVariables.get('supplierId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List suppliers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/suppliers"
          }
        }
      ]
    },
    {
      "name": "02 - Products and inventory",
      "item": [
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Product\",\n  \"sku\": \"POSTMAN-{{runId}}\",\n  \"description\": \"Created by the StockFlow Postman collection\",\n  \"category\": \"Testing\",\n  \"quantity\": 10,\n  \"minimumStock\": 5,\n  \"price\": 249.90,\n  \"supplierId\": {{supplierId}}\n}"
            },
            "url": "{{baseUrl}}/api/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Product was created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.collectionVariables.set('productId', pm.response.json().id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Record incoming inventory",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"type\": \"IN\",\n  \"quantity\": 5,\n  \"reason\": \"Postman collection test stock\"\n}"
            },
            "url": "{{baseUrl}}/api/inventory/movements"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Inventory movement was recorded', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.json().newQuantity).to.eql(15);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Search products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/search?name=Postman"
          }
        },
        {
          "name": "List low-stock products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/low-stock"
          }
        },
        {
          "name": "List product inventory movements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/movements/product/{{productId}}"
          }
        },
        {
          "name": "List supplier products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/suppliers/{{supplierId}}/products"
          }
        }
      ]
    },
    {
      "name": "03 - Purchase order workflow",
      "item": [
        {
          "name": "Create purchase order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": {{supplierId}}\n}"
            },
            "url": "{{baseUrl}}/api/purchase-orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Purchase order was created as draft', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('DRAFT');",
                  "  pm.collectionVariables.set('purchaseOrderId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Add purchase order item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 5,\n  \"unitPrice\": 200.00\n}"
            },
            "url": "{{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/items"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Purchase order total was calculated', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().totalAmount).to.eql(1000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Set purchase order to ORDERED",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ORDERED\"\n}"
            },
            "url": "{{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/status"
          }
        },
        {
          "name": "Receive purchase order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/receive"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Purchase order was received', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('RECEIVED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get purchase order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}"
          }
        }
      ]
    },
    {
      "name": "04 - Sales order workflow",
      "item": [
        {
          "name": "Create sales order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Postman Customer {{runId}}\",\n  \"customerEmail\": \"customer.{{runId}}@postman.test\"\n}"
            },
            "url": "{{baseUrl}}/api/sales-orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sales order was created as draft', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('DRAFT');",
                  "  pm.collectionVariables.set('salesOrderId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Add sales order item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2,\n  \"unitPrice\": 249.90\n}"
            },
            "url": "{{baseUrl}}/api/sales-orders/{{salesOrderId}}/items"
          }
        },
        {
          "name": "Set sales order to CONFIRMED",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": "{{baseUrl}}/api/sales-orders/{{salesOrderId}}/status"
          }
        },
        {
          "name": "Set sales order to PAID",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PAID\"\n}"
            },
            "url": "{{baseUrl}}/api/sales-orders/{{salesOrderId}}/status"
          }
        },
        {
          "name": "Ship sales order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/sales-orders/{{salesOrderId}}/ship"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sales order was shipped', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('SHIPPED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get sales order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/sales-orders/{{salesOrderId}}"
          }
        }
      ]
    },
    {
      "name": "05 - Finance and audit",
      "item": [
        {
          "name": "List ledger transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ledger/transactions"
          }
        },
        {
          "name": "Get ledger summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ledger/summary"
          }
        },
        {
          "name": "Get monthly ledger summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ledger/summary/monthly"
          }
        },
        {
          "name": "List audit logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/audit-logs"
          }
        },
        {
          "name": "Get purchase order audit logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/audit-logs/entity/PurchaseOrder/{{purchaseOrderId}}"
          }
        },
        {
          "name": "Get sales order audit logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/audit-logs/entity/SalesOrder/{{salesOrderId}}"
          }
        }
      ]
    },
    {
      "name": "06 - Users",
      "item": [
        {
          "name": "Create employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Employee {{runId}}\",\n  \"email\": \"employee.{{runId}}@postman.test\",\n  \"password\": \"postman-password-123\",\n  \"role\": \"EMPLOYEE\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Employee was created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.role).to.eql('EMPLOYEE');",
                  "  pm.collectionVariables.set('userId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get employee",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    }
  ]
}
